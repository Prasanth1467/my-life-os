{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life OS",
  "version": "0.1.0",
  "identifier": "com.evrpr.lifeos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npx --yes cross-env NEXT_STATIC_EXPORT=1 npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Life OS",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}

