# Copy to .env.local (never commit .env.local). Keys from Supabase Dashboard → Project Settings → API.
# If keys were ever committed publicly, rotate them in Supabase (Settings → API → regenerate).

# Browser-safe (embedded in the Next.js client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (Vercel / CI — do not use NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Vercel Cron: same value as in Vercel → Environment Variables. Vercel sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# GitHub Action "Supabase DB push": create a token at https://supabase.com/dashboard/account/tokens
# and add SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF as repository secrets.
