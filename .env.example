# Copy to `.env` or `.env.local` (both are loaded by Next.js; `.env.local` overrides).
# Restart `npm run dev` after changing env files.

# Option A — recommended (exposed to the browser bundle):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Or legacy anon JWT:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Option B — same as Supabase CLI / many tutorials (also wired for the client via next.config.mjs):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Never put the service_role secret in any NEXT_PUBLIC_ or SUPABASE_ANON_KEY variable.

# Server-only (API routes / cron — not sent to the browser):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Must match Vercel → Project → Settings → Environment Variables → CRON_SECRET.
# Vercel Cron calls GET /api/cron/maintenance with Authorization: Bearer <CRON_SECRET>.
# Local: set the same value to run `npm run cron:test` (dev server on port 3000).
CRON_SECRET=

# GitHub Action "Supabase DB push": SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF in repo secrets.
