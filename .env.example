# Browser-safe (Vercel + local). Use Project URL + anon/publishable key from Supabase Dashboard → Connect.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy name still supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only: never expose to the client. Used by /api/cron/maintenance only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Vercel Cron: set the same value in Vercel → Environment → CRON_SECRET
CRON_SECRET=generate_a_long_random_string
